{
  "name": "ai-executive",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NEXT_DIST_DIR=.next-v1 next dev -p 4312 --webpack",
    "dev:v1": "cross-env NEXT_DIST_DIR=.next-v1 next dev -p 4312 --webpack",
    "dev:v2": "cross-env NEXT_DIST_DIR=.next-v2 next dev -p 4313 --webpack",
    "dev:compare": "cross-env NEXT_DIST_DIR=.next-compare next dev -p 4314 --webpack",
    "dev:all": "concurrently --names \"v1,v2,compare\" --prefix-colors \"magenta,cyan,yellow\" \"npm run dev:v1\" \"npm run dev:v2\" \"npm run dev:compare\"",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@runwayml/sdk": "^3.20.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@upstash/redis": "^1.37.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "posthog-js": "^1.372.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "replicate": "^1.4.0",
    "tailwind-merge": "^3.5.0",
    "twitter-api-v2": "^1.29.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
